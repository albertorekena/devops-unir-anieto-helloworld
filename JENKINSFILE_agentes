pipeline {
  agent none

  stages {
    stage('Conseguir Código del Repositorio') {
      agent { label 'principal' }
      options { skipDefaultCheckout() }
      steps {
        sh 'echo "AGENTE: $(whoami) @ $(hostname)"'
        cleanWs()
        git 'https://github.com/albertorekena/devops-unir-anieto-helloworld'
        stash name: 'codigo-fuente', includes: '**/*'
      }
    }

    stage('Tests') {
      parallel {
        stage('Unit') {
          agent { label 'secundario1' }
          options { skipDefaultCheckout() }
          steps {
            sh 'echo "AGENTE: $(whoami) @ $(hostname)"'
            cleanWs()
            unstash 'codigo-fuente'
            catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
              sh '''
                export PYTHONPATH=$WORKSPACE
                coverage run --source=app -m pytest --junitxml=result-unit.xml test/unit
                coverage xml
              '''
            }
            junit 'result-unit.xml'
            publishCoverage adapters: [coberturaAdapter('coverage.xml')],
                     failUnhealthy: true,
                     globalThresholds: [
                       [thresholdTarget: 'Line',        unhealthyThreshold: 85.0, unstableThreshold: 95.0],
                       [thresholdTarget: 'Conditional', unhealthyThreshold: 80.0, unstableThreshold: 90.0]
                     ]
          }
        }

        stage('Static') {
          agent { label 'secundario1' }
          options { skipDefaultCheckout() }
          steps {
            sh 'echo "AGENTE: $(whoami) @ $(hostname)"'
            cleanWs()
            unstash 'codigo-fuente'
            sh 'flake8 --format=pylint app/ test/ > flake8.out || true'
            recordIssues tools: [flake8(pattern: 'flake8.out')],
                   enabledForFailure: true,
                   qualityGates: [
                     [threshold: 8,  type: 'TOTAL', criticality: 'UNSTABLE'],
                     [threshold: 10, type: 'TOTAL', criticality: 'FAILURE']
                   ]
          }
        }

        stage('Security') {
          agent { label 'secundario1' }
          options { skipDefaultCheckout() }
          steps {
            sh 'echo "AGENTE: $(whoami) @ $(hostname)"'
            cleanWs()
            unstash 'codigo-fuente'
            sh 'bandit -r app/ -f custom -o bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}" --exit-zero'
            recordIssues tools: [pyLint(name: 'Bandit', pattern: 'bandit.out')],
                   enabledForFailure: true,
                   qualityGates: [
                     [threshold: 2, type: 'TOTAL', criticality: 'UNSTABLE'],
                     [threshold: 4, type: 'TOTAL', criticality: 'FAILURE']
                   ]
          }
        }

        stage('Rest') {
          agent { label 'secundario2' }
          options { skipDefaultCheckout() }
          steps {
            sh 'echo "AGENTE: $(whoami) @ $(hostname)"'
            cleanWs()
            unstash 'codigo-fuente'
            sh '''
              [ -f test/wiremock/wiremock-standalone.jar ] || curl -sLo test/wiremock/wiremock-standalone.jar \
                https://repo1.maven.org/maven2/com/github/tomakehurst/wiremock-standalone/2.27.2/wiremock-standalone-2.27.2.jar
              export FLASK_APP=app/api.py
              export FLASK_ENV=development
              flask run --port=5001 &
              java -jar test/wiremock/wiremock-standalone.jar --port 9090 --root-dir test/wiremock &
              sleep 3
              export PYTHONPATH=$WORKSPACE
              pytest --junitxml=result-rest.xml test/rest
            '''
            junit 'result-rest.xml'
          }
        }

      }
    }

    stage('Performance') {
      agent { label 'principal' }
      options { skipDefaultCheckout() }
      steps {
        sh 'echo "AGENTE: $(whoami) @ $(hostname)"'
        cleanWs()
        unstash 'codigo-fuente'
        sh '''
          [ -d $HOME/tools/apache-jmeter-5.4.3 ] || {
            curl -sLo /tmp/apache-jmeter-5.4.3.tgz https://archive.apache.org/dist/jmeter/binaries/apache-jmeter-5.4.3.tgz
            mkdir -p $HOME/tools/
            tar -xzf /tmp/apache-jmeter-5.4.3.tgz -C $HOME/tools/
          }
          export FLASK_APP=app/api.py
          flask run --port=5001 &
          sleep 3
          $HOME/tools/apache-jmeter-5.4.3/bin/jmeter -n -t test/jmeter/flask.jmx -l result-jmeter.jtl
        '''
        perfReport sourceDataFiles: 'result-jmeter.jtl'
      }
    }
  }
}