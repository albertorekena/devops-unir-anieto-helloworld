pipeline {
    // agent any
    agent none

    stages {
        stage('Get Code') {
            agent any
            steps {
                cleanWs()
                git 'https://github.com/albertorekena/devops-unir-anieto-helloworld'
            }
        }

    stage('Tests') {
        parallel {
            stage('Unit') {
                agent any
                steps {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                        sh '''
                            export PYTHONPATH=$WORKSPACE
                            pytest --junitxml=result-unit.xml test/unit
                        '''
                    }
                }
            }

            stage('Rest') {
                agent any
                steps {
                    sh '''
                        curl -sLo test/wiremock/wiremock-standalone.jar \
                            https://repo1.maven.org/maven2/com/github/tomakehurst/wiremock-standalone/2.27.2/wiremock-standalone-2.27.2.jar
                        export FLASK_APP=app/api.py
                        export FLASK_ENV=development
                        flask run --port=5001 &
                        java -jar test/wiremock/wiremock-standalone.jar --port 9090 --root-dir test/wiremock &
                        sleep 3
                        export PYTHONPATH=$WORKSPACE
                        pytest --junitxml=result-rest.xml test/rest
                    '''
                    stash name: 'rest-results', includes: 'result-rest.xml'
                }
            }
        }
    }

    stage ('Results') {
        agent any
        steps {
            unstash 'rest-results'
            junit 'result*.xml'
        }
    }
  }
}